# ── AI-Ops Sentinel Production — Root Environment Template ────────────────────
# Used by docker-compose.prod.yml for the full production stack on EC2.
# Copy to .env and fill in real values. NEVER commit .env.
#
# In production, prefer your cloud provider's Secrets Manager over a flat file:
#   AWS: Secrets Manager / Parameter Store
#   GCP: Secret Manager
#   Vercel: Environment Variables UI

# ── AI / RAG ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=aiops-incidents

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48

# ── Database ──────────────────────────────────────────────────────────────────
# Used to derive DATABASE_URL in docker-compose.prod.yml.
# Set to a strong password — it's used both by PostgreSQL and the connection string.
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_USER=aiops
POSTGRES_DB=aiops_sentinel

# Or override the entire URL to point to an external RDS instance:
# DATABASE_URL=postgresql://user:pass@your-rds-endpoint:5432/aiops_sentinel

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL where your frontend is deployed (never use * in production).
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ── Log Collection ────────────────────────────────────────────────────────────
# Absolute path on the EC2 host where your application writes logs.
# The log-collector container will mount this directory read-only.
LOG_VOLUME_PATH=/var/log/aiops

# ── Cloud Kafka Auth (only needed if replacing bundled Kafka with MSK/Confluent)
# KAFKA_SASL_MECHANISM=plain
# KAFKA_SASL_USERNAME=your-api-key
# KAFKA_SASL_PASSWORD=your-api-secret
