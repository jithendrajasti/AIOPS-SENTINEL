# ── AI-Ops Sentinel Central Brain — Environment Variables ─────────────────────
# Copy to .env and fill in real values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Set to your frontend domain in production — NEVER use * in production
CORS_ORIGIN=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aiops:aiops_secret@localhost:5432/aiops_sentinel

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=raw-logs
KAFKA_CLIENT_ID=aiops-central-brain
KAFKA_GROUP_ID=aiops-central-brain-group
# Set to "false" to skip Kafka consumer startup in local dev (HTTP/socket only)
USE_KAFKA=false

# ── Cloud Kafka Auth (Confluent Cloud / AWS MSK) ──────────────────────────────
# Uncomment and set when connecting to a managed Kafka cluster.
# KAFKA_SASL_MECHANISM=plain            # or scram-sha-512 for MSK
# KAFKA_SASL_USERNAME=your-api-key
# KAFKA_SASL_PASSWORD=your-api-secret

# ── Kafka Topic Config ────────────────────────────────────────────────────────
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION=1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI / RAG Pipeline ─────────────────────────────────────────────────────────
# Set MOCK_AI=true to use DB-backed mock responses without calling any external AI.
MOCK_AI=false

# NVIDIA NIM (DeepSeek via NVIDIA AI Endpoints — get your key at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=aiops-incidents
