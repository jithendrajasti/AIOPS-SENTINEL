{
  "name": "aiops-central-brain",
  "version": "1.0.0",
  "description": "AI-Ops Sentinel — Kafka consumer, anomaly detection, RAG pipeline, Socket.IO gateway",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "@langchain/pinecone": "^1.0.3",
    "@pinecone-database/pinecone": "^5.1.2",
    "@prisma/adapter-pg": "^5.22.0",
    "@prisma/client": "^5.18.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "langchain": "^1.5.2",
    "pg": "^8.22.0",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "ts-jest": "^29.2.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ]
  }
}
