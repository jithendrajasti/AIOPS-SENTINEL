# ── AI-Ops Sentinel Log Collector — Environment Variables ─────────────────────
# Copy to .env and fill in real values. Never commit .env.

# ── Log Source ────────────────────────────────────────────────────────────────
# Path to the log file to tail.
# Dev:  ./sample.log   (run "npm run write:logs" to generate test data)
# Prod: /var/log/nginx/error.log  or any application log file
LOG_FILE_PATH=./sample.log

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=raw-logs
KAFKA_CLIENT_ID=aiops-log-collector
# Set to "true" to send to real Kafka, "false" for console-only [MOCK] output
USE_KAFKA=false

# ── Cloud Kafka Auth (Confluent Cloud / AWS MSK / Upstash) ────────────────────
# KAFKA_SASL_MECHANISM=plain            # or scram-sha-512 for MSK
# KAFKA_SASL_USERNAME=your-api-key
# KAFKA_SASL_PASSWORD=your-api-secret

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=500

# ── Local dev log writer ──────────────────────────────────────────────────────
# Controls the "npm run write:logs" script
WRITE_INTERVAL_MS=800
BURST_EVERY=30
BURST_SIZE=15
