# ── AI-Ops Sentinel Frontend — Environment Variables ──────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and never committed.

# ── Backend API ───────────────────────────────────────────────────────────────
# Point to your deployed central-brain URL in production.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match the exact URL your app is served from.
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
